@echo off
REM Автоматический парсинг новостей с экспортом в Excel
REM Запуск: auto_parse_export.bat [параметры]

echo ========================================
echo АВТОМАТИЧЕСКИЙ ПАРСИНГ С ЭКСПОРТОМ В EXCEL
echo ========================================

REM Проверяем наличие Python
where py >nul 2>nul
if %errorlevel% neq 0 (
    echo Ошибка: Python не найден. Установите Python 3.8+ или используйте 'python' вместо 'py'
    pause
    exit /b 1
)

echo.
echo Параметры по умолчанию:
echo - Парсинг за последние 7 дней
echo - 200 новостей на источник
echo - Анализ 1000 последних новостей
echo - Вывод топ-10 компаний
echo.

echo Запуск парсинга с автоматическим экспортом в Excel...
echo.

REM Запускаем команду parse-and-export
py cli.py parse-and-export %*

if %errorlevel% equ 0 (
    echo.
    echo ========================================
    echo ОПЕРАЦИЯ УСПЕШНО ЗАВЕРШЕНА!
    echo ========================================
    echo.
    echo Все новости сохранены в базу данных
    echo Результаты экспортированы в Excel файл
    echo Файл создан в текущей директории: news_analysis_*.xlsx
) else (
    echo.
    echo ========================================
    echo ОШИБКА ПРИ ВЫПОЛНЕНИИ ОПЕРАЦИИ
    echo ========================================
)

echo.
pause